# Base de datos
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/devmonitor

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Servidor
APP_HOST=0.0.0.0
APP_PORT=8000
# Orígenes CORS separados por comas (sin IPs de LAN hardcodeadas)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Seguridad — ⚠️ CAMBIAR OBLIGATORIAMENTE antes de exponer la API
DEVMONITOR_API_KEY=<GENERA-TU-CLAVE-AQUÍ>

# Configuración
DEBUG=true

# Frontend (Vite — las variables VITE_ se exponen al browser)
VITE_API_BASE_URL=http://localhost:8000
VITE_API_KEY=<MISMA-CLAVE-QUE-DEVMONITOR_API_KEY>

# Seed demo — establecer a true para permitir DROP TABLE sin confirmación
# ALLOW_SEED_RESET=true